{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Producto",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "nombreProducto": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "nombreProducto"
    },
    "imagenes": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "activo": {
      "type": "boolean",
      "default": false
    },
    "precioBase": {
      "type": "decimal",
      "min": 0,
      "required": true
    },
    "stock": {
      "type": "integer",
      "min": 0,
      "required": true
    },
    "subcategoria": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::subcategoria.subcategoria",
      "inversedBy": "productos"
    },
    "cantidadPorCaja": {
      "type": "integer"
    },
    "detalles": {
      "type": "text"
    },
    "descripcionCantidad": {
      "type": "text"
    },
    "marca": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::marca.marca",
      "inversedBy": "productos"
    },
    "Popular": {
      "type": "boolean",
      "default": false
    },
    "Subtitulo": {
      "type": "text"
    },
    "unidadMinima": {
      "type": "integer"
    },
    "porcentajeDescuento": {
      "type": "integer",
      "default": 0,
      "max": 100
    }
  }
}
